# Required
OPENROUTER_API_KEY=sk-or-...

# Optional — backup models
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Pipeline settings (override defaults)
CONCURRENCY=8           # parallel API requests
TEMPERATURE=0.7         # primary sweep temperature
REPLICATES=30           # replicates per condition
MODEL=openrouter/openai/gpt-oss-120b
PROVIDER=Fireworks      # OpenRouter inference provider to pin
DB_PATH=outputs/runs.db
CACHE_DIR=outputs/cache
